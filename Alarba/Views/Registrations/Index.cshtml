@model IEnumerable<Alarba.Models.Registrations>

@{
    ViewData["Title"] = "Index";
}

<h1>Registration</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search registrations..." />
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.regId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RegistraionId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.regDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RegistrationFee)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.regPayOptions)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.regId)
            </td>
            <td>
                @Html.DisplayFor(model => item.RegistraionId)
            </td>
            <td>
                @Html.DisplayFor(model => item.regDate)
            </td>
            <td>
                @Html.DisplayFor(model => item.RegistrationFee)
            </td>
            <td>
                @Html.DisplayFor(model => item.regPayOptions)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
